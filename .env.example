# .env.example — wapp-cloud-platform (dev)
#
# Plantilla versionada (patrón EduGo). Copia a `.env` y ajusta; `.env` está en .gitignore.
# El binario NO lee este archivo por sí solo: cárgalo en la shell antes de arrancar:
#     set -a; . ./.env; set +a
#     go run ./cmd/server serve
# Todo aquí es override de los defaults de internal/platform/config (prefijo WAPP_).
#
# ─── Puertos: BANDA wApp 81xx (aparte de EduGo 80xx) ──────────────────────────
# Ver docs/CONVENCIONES.md → "Rango de puertos por ecosistema".
#   8100  HTTP health/admin (/healthz, /admin/leases/revoke)
#   8101  gRPC CloudLink (mTLS estricto, stream bidi)
#   8102  gRPC Enrollment (TLS de servidor; el Edge enrola antes de tener cert)
#   8103  HTTP API pública /api/v1 (terceros; Plan 018, listener aparte del admin)
WAPP_HTTP_ADDR=:8100
WAPP_GRPC_CONNECT_ADDR=:8101
WAPP_GRPC_ENROLL_ADDR=:8102
WAPP_PUBLIC_HTTP_ADDR=:8103

# ─── IAM / JWT (Plan 018) ─────────────────────────────────────────────────────
# Secreto HS256 que firma los tokens de usuario y el service token M2M. NUNCA lo
# pongas real aquí (este archivo se versiona): el valor REAL va SOLO en `.env`
# (no versionado). Zero-knowledge: en prod (WAPP_APP_ENV=prod) es OBLIGATORIO y el
# arranque falla si falta; en dev, si queda vacío se genera uno efímero con warning
# (los tokens no sobreviven a un reinicio). Genera uno con: openssl rand -base64 32
WAPP_JWT_SECRET=<pon-un-secreto-fuerte-en-.env-NO-aqui>
WAPP_JWT_ISSUER=wapp-cloud
WAPP_SERVICE_JWT_AUDIENCE=wapp-public-api
# Clave privada EC P-256 que firma los tokens de usuario en ES256 (ADR-0019, Plan
# 028). Acepta PKCS#8 y SEC1. En prod (WAPP_APP_ENV=prod) es OBLIGATORIA y el
# arranque falla si falta, si los permisos son más laxos que 0600 o si la clave es
# inválida; en dev, si queda vacía se genera un par efímero con warning (los tokens
# no sobreviven a un reinicio). Genérala y protégela con:
#   openssl ecparam -name prime256v1 -genkey -noout | openssl pkcs8 -topk8 -nocrypt -out jwt-es256.pem && chmod 600 jwt-es256.pem
WAPP_JWT_EC_PRIVATE_KEY_FILE=<ruta-al-PEM-en-.env-NO-aqui>
# Key id (`kid`) activo que el emisor ES256 estampa y que el validador dual usa
# para seleccionar la pública. Convención es256-YYYYMMDD; vacío en dev ⇒ "es256-dev".
WAPP_JWT_KID=es256-dev

# ─── Rate-limit de la API pública (Plan 018 · T10, R11) ───────────────────────
# Token-bucket EN MEMORIA (sin broker). PUBLIC_* acota cada credencial
# (api-key/tenant) en las rutas /api/v1 de operación; LOGIN_* acota por IP el
# /api/v1/auth/login (anti fuerza bruta). Al exceder: 429 con Retry-After.
# Defaults sanos; sube en despliegues de alto tráfico.
WAPP_RATELIMIT_PUBLIC_RPS=20
WAPP_RATELIMIT_PUBLIC_BURST=40
WAPP_RATELIMIT_LOGIN_PER_MIN=10
WAPP_RATELIMIT_LOGIN_BURST=5

# ─── Postgres: contenedor COMPARTIDO con EduGo (edugo-postgres, localhost:5432) ─
# wApp NO levanta contenedor propio: reutiliza la instancia de EduGo con su
# PROPIA base y rol (créalos con deploy/bootstrap-shared-db.sql). Ver deploy/README.md.
WAPP_DB_HOST=localhost
WAPP_DB_PORT=5432
WAPP_DB_USER=wapp
WAPP_DB_PASSWORD=wapp
WAPP_DB_NAME=wapp_cloud
WAPP_DB_SSLMODE=disable

# ─── Entorno / logging ────────────────────────────────────────────────────────
WAPP_APP_ENV=dev
WAPP_LOG_LEVEL=info
WAPP_LOG_JSON=false

# ─── Almacén de objetos: Cloudflare R2 (S3-compatible; NO AWS, sin costo) ─────
# Plan 017 (PDF/Media). REUTILIZA la cuenta/bucket de EduGo (alpha): mismos valores
# que edugo-api-learning/.env-cloud. Los valores REALES (endpoint con account-id,
# access key y secret) van SOLO en `.env` (NO versionado); aquí van los nombres.
# R2 free permite varios buckets; por ahora reusamos `edugo-materials` con un
# PREFIJO propio de wApp para aislar sin crear nada nuevo. Cambiar a bucket propio
# `wapp-media` es solo cambiar WAPP_STORAGE_S3_BUCKET (configurable).
WAPP_STORAGE_S3_REGION=us-east-1
WAPP_STORAGE_S3_BUCKET=edugo-materials
WAPP_STORAGE_S3_PREFIX=wapp/
WAPP_STORAGE_S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
WAPP_STORAGE_S3_ACCESS_KEY_ID=<usa-el-de-edugo-api-learning/.env-cloud>
WAPP_STORAGE_S3_SECRET_ACCESS_KEY=<usa-el-de-edugo-api-learning/.env-cloud>
WAPP_STORAGE_S3_PRESIGN_EXPIRY=15m

# ─── PKI de dev (genera con scripts/gen-dev-certs.sh) ─────────────────────────
# WAPP_PKI_SERVER_CERT_FILE=certs/server.crt
# WAPP_PKI_SERVER_KEY_FILE=certs/server.key
# WAPP_PKI_CA_CERT_FILE=certs/ca.crt
# WAPP_PKI_CA_KEY_FILE=certs/ca.key
